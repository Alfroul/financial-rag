# MiMo API Key（小米大模型平台）
# 获取方式：访问 https://platform.xiaomimimo.com 注册获取 API Key
MIMO_API_KEY=your_key_here
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# SiliconFlow API Key（已弃用，保留向后兼容）
# 获取方式：访问 https://siliconflow.cn 注册获取免费 API Key
SILICONFLOW_API_KEY=your_siliconflow_key_here

# Langfuse 可观测性配置
# 获取方式：访问 https://cloud.langfuse.com 注册获取 Key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Neo4j 图数据库配置
NEO4J_PASSWORD=your_neo4j_password_here
